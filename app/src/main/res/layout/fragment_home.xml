<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/md_theme_background"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Usuario -->
        <LinearLayout
            android:id="@+id/layoutUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/bg_tile_ver"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imgRol"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_person"
                android:contentDescription="@null"
                app:tint="@color/md_text_primary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/md_text_primary"/>

                <TextView
                    android:id="@+id/tvRolUsuario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROL"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/bg_role_badge"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Título grande y subtítulo -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
        android:textStyle="bold"
        android:textSize="28sp"
        android:textColor="@color/md_text_primary" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/que_deseas_hacer_hoy"
        android:layout_marginTop="4dp"
        android:textSize="16sp"
        android:textColor="@color/md_text_primary" />

        <!-- Grid 2x2 de tiles -->
        <LinearLayout
            android:id="@+id/gridTiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <!-- FILA 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Registrar -->
                <LinearLayout
                    android:id="@+id/cardRegistrar"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_registrar"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card"
                    android:contentDescription="@string/cd_card_registrar">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_check_circle"
                        android:importantForAccessibility="no"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/registrar"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent"/>

                <!-- Ver -->
                <LinearLayout
                    android:id="@+id/cardVer"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_ver"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card"
                    android:contentDescription="@string/cd_card_ver">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_article"
                        android:importantForAccessibility="no"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/ver"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

            </LinearLayout>

            <!-- FILA 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Reportes -->
                <LinearLayout
                    android:id="@+id/cardReportes"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_reportes"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card"
                    android:contentDescription="@string/cd_card_reportes">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_bar_chart"
                        android:importantForAccessibility="no"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/reportes"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent"/>

                <!-- Usuarios -->
                <LinearLayout
                    android:id="@+id/cardUsuarios"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_usuarios"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card"
                    android:contentDescription="@string/cd_card_usuarios">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_person"
                        android:importantForAccessibility="no"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/usuarios"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

            </LinearLayout>

            <!-- FILA 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Empleados -->
                <LinearLayout
                    android:id="@+id/cardEmpleados"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_usuarios"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Empleados"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

                <!-- Espacio entre cards -->
                <Space
                    android:layout_width="16dp"
                    android:layout_height="match_parent"/>

                <!-- Ver Empleados -->
                <LinearLayout
                    android:id="@+id/cardVerEmpleados"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tile_usuarios"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/ripple_card">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_ver_empleados"
                        app:tint="@color/md_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ver Empleados"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/md_text_primary"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
        <!-- Botón Cerrar Sesión (pill) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCerrarSesion"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_logout_pill"
            android:text="@string/cerrar_sesion"
            android:textAllCaps="false"
            android:textColor="@color/logout_background"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/logout_red"
            app:iconPadding="8dp" />
    </LinearLayout>
</ScrollView>
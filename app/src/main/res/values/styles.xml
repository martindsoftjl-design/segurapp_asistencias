<resources>

    <!-- TITULOS -->
    <style name="Text.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/md_text_primary</item>
    </style>

    <style name="Text.Subtitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_text_primary</item>
    </style>

    <!-- BOTÓN GRANDE REDONDEADO (como el diseño) -->
    <style name="Btn.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">60dp</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- BOTÓN OUTLINED -->
    <style name="Btn.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">60dp</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TEXTO GENERAL -->
    <style name="Text">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/md_text_primary</item>
    </style>

</resources>